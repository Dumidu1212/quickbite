# =============================================
# QuickBite — Environment Variables Reference
# Copy this to .env and fill in real values.
# NEVER commit the actual .env file.
# =============================================

# --- User Service (port 3001) ---
USER_SERVICE_PORT=3001
MONGODB_URI_USERS=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/users-db
JWT_SECRET=change-this-to-a-random-32-char-string-minimum
JWT_EXPIRES_IN=24h
BCRYPT_ROUNDS=12
NODE_ENV=development

# --- Menu Service (port 8001) ---
MENU_SERVICE_PORT=8001
MONGODB_URI_MENU=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/menu-db

# --- Order Service (port 3002) ---
ORDER_SERVICE_PORT=3002
MONGODB_URI_ORDERS=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/orders-db
USER_SERVICE_URL=http://user-service:3001
MENU_SERVICE_URL=http://menu-service:8001
SERVICEBUS_CONN=Endpoint=sb://NAMESPACE.servicebus.windows.net/;SharedAccessKeyName=...
SERVICEBUS_QUEUE_NAME=order-events

# --- Notify Service (port 8002) ---
NOTIFY_SERVICE_PORT=8002
SENDGRID_API_KEY=SG.xxxxxxxxxxxx
SENDGRID_FROM_EMAIL=noreply@quickbite.com
INTERNAL_API_KEY=change-this-random-string
SERVICEBUS_CONN=Endpoint=sb://NAMESPACE.servicebus.windows.net/;SharedAccessKeyName=...
SERVICEBUS_QUEUE_NAME=order-events

# --- Frontend ---
VITE_API_BASE_URL=http://localhost:3000
