# =================================================================
# QuickBite — Environment Variable Reference
#
# HOW TO USE:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in real values in .env
#   3. NEVER commit the .env file — it is in .gitignore
#
# WHERE TO GET EACH VALUE:
#   MONGODB_URI_*    → MongoDB Atlas dashboard → Connect → Drivers
#   JWT_SECRET       → generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#   SENDGRID_API_KEY → sendgrid.com → Settings → API Keys
#   SERVICEBUS_CONN  → Azure Portal → Service Bus → Shared Access Policies
# =================================================================

# ── USER SERVICE (Node.js, port 3001) ─────────────────────────────
USER_SERVICE_PORT=3001
MONGODB_URI_USERS=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/users-db?retryWrites=true&w=majority
JWT_SECRET=replace-with-64-char-random-hex-string
JWT_EXPIRES_IN=24h
BCRYPT_ROUNDS=12
NODE_ENV=development

# ── MENU SERVICE (Python/FastAPI, port 8001) ──────────────────────
MENU_SERVICE_PORT=8001
MONGODB_URI_MENU=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/menu-db?retryWrites=true&w=majority

# ── ORDER SERVICE (Node.js, port 3002) ────────────────────────────
ORDER_SERVICE_PORT=3002
MONGODB_URI_ORDERS=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/orders-db?retryWrites=true&w=majority
# These URLs work in docker-compose (service names resolve to containers)
# For local dev without docker, change to localhost:3001 and localhost:8001
USER_SERVICE_URL=http://user-service:3001
MENU_SERVICE_URL=http://menu-service:8001
SERVICEBUS_CONN=Endpoint=sb://<namespace>.servicebus.windows.net/;SharedAccessKeyName=RootManageSharedAccessKey;SharedAccessKey=<key>
SERVICEBUS_QUEUE_NAME=order-events

# ── NOTIFY SERVICE (Python/FastAPI, port 8002) ────────────────────
NOTIFY_SERVICE_PORT=8002
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=noreply@quickbite.com
INTERNAL_API_KEY=replace-with-random-string-for-internal-calls
# Notify service also needs Service Bus to consume events
SERVICEBUS_CONN=Endpoint=sb://<namespace>.servicebus.windows.net/;SharedAccessKeyName=RootManageSharedAccessKey;SharedAccessKey=<key>
SERVICEBUS_QUEUE_NAME=order-events

# ── FRONTEND (React/Vite, port 5173) ──────────────────────────────
# In docker-compose: points to API Management or directly to services
# In production: points to Azure API Management URL
VITE_API_BASE_URL=http://localhost:3001
